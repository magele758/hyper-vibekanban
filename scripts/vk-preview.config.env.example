# vk-isolate preview mode configuration (remote testing)
#
# Copy this to ~/.config/vk-preview/config.env and fill in your values.
# DO NOT commit the real config.env — it contains your SSH host and paths.
#
# Example:
#   mkdir -p ~/.config/vk-preview
#   cp scripts/vk-preview.config.env.example ~/.config/vk-preview/config.env
#   # Edit ~/.config/vk-preview/config.env with your real values

# SSH host (from ~/.ssh/config) for the remote preview machine.
# Example: "ubuntu1" or "dev-server"
VK_PREVIEW_HOST=your-ssh-host

# Absolute path to the repo clone on the remote machine.
# Example: "/home/ubuntu/vibe-kanban" or "~/projects/hyper-vibekanban"
VK_PREVIEW_DIR=~/path/to/repo-clone

# Git remote name to push/pull from (default: origin).
VK_PREVIEW_GIT_REMOTE=origin

# How to sync code to the remote machine:
#   "git" (default) — push from local, pull on remote
#   "rsync" — direct rsync over SSH
VK_PREVIEW_SYNC_METHOD=git

# Public base URL for the remote frontend (browser access).
# Replace YOUR_HOST with the Tailscale hostname or public IP.
# Example: "http://my-dev-machine.tailnet-abc.ts.net:23000"
VK_PREVIEW_PUBLIC_BASE=http://YOUR_HOST:23000

# Optional: Port offset base (default 23000).
# Remote will use:
#   Frontend: 23001, Backend: 23002, PreviewProxy: 23003
#   Remote: 23000, Relay: 28082, DB: 127.0.0.1:25433
VK_PREVIEW_PORTS_BASE=23000
