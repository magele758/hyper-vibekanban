{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                id              AS \"id!: Uuid\",\n                autopilot_id    AS \"autopilot_id!: Uuid\",\n                status          AS \"status!: AutopilotRunStatus\",\n                planned_at      AS \"planned_at!: DateTime<Utc>\",\n                started_at,\n                completed_at,\n                issue_id,\n                agent_task_id,\n                error_message,\n                created_at      AS \"created_at!: DateTime<Utc>\"\n            FROM autopilot_runs\n            WHERE autopilot_id = $1\n            ORDER BY created_at DESC\n            LIMIT $2\n            ",
