  "query": "\n            SELECT\n                id              AS \"id!: Uuid\",\n                project_id      AS \"project_id!: Uuid\",\n                autopilot_id,\n                token           AS \"token!\",\n                name            AS \"name!\",\n                enabled         AS \"enabled!\",\n                created_at      AS \"created_at!: DateTime<Utc>\"\n            FROM webhook_endpoints\n            WHERE project_id = $1\n            ORDER BY created_at DESC\n            ",
