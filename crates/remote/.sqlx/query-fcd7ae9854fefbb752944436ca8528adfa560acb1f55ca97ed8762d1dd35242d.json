  "query": "\n                SELECT\n                    id                  AS \"id!: Uuid\",\n                    project_id          AS \"project_id!: Uuid\",\n                    agent_id,\n                    issue_id,\n                    created_by_user_id,\n                    title,\n                    external_agent_id,\n                    created_at          AS \"created_at!: DateTime<Utc>\",\n                    updated_at          AS \"updated_at!: DateTime<Utc>\"\n                FROM copilot_sessions\n                WHERE project_id = $1\n                ORDER BY updated_at DESC\n                ",
