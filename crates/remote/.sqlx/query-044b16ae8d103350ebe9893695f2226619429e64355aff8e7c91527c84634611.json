  "query": "\n            SELECT\n                id          AS \"id!: Uuid\",\n                issue_id    AS \"issue_id!: Uuid\",\n                user_id,\n                agent_id,\n                squad_id,\n                assigned_at AS \"assigned_at!: DateTime<Utc>\"\n            FROM issue_assignees\n            WHERE issue_id IN (SELECT id FROM issues WHERE project_id = $1)\n            ",
